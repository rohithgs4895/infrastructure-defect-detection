# -- Raw data (too large for git -- download separately) ---------------------
data/raw/

# -- Large processed data (regenerated by georeference.py / NBI parser) -----
data/processed/nbi_bridges.csv

# -- Trained models (binary blobs -- too large for git) ----------------------
models/*.keras

# -- Shapefile sidecar files (regenerated by georeference.py) ----------------
# Keep .shp geometry; ignore all sidecars
outputs/*.dbf
outputs/*.shx
outputs/*.prj
outputs/*.cpg
outputs/*.shp.MAT.*
outputs/*.sr.lock
outputs/*.sbn
outputs/*.sbx
outputs/*.shp.xml

# -- ArcGIS raster outputs (large binary, regenerated by arcgis_analysis.py) -
outputs/*.tif
outputs/*.tfw
outputs/*.tif.aux.xml
outputs/*.tif.xml

# -- ArcGIS layout exports ---------------------------------------------------
outputs/*.pdf

# -- Python bytecode ---------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# -- Environment and secrets -------------------------------------------------
.env
.env.*
*.env
secrets.toml
.streamlit/secrets.toml

# -- OS artifacts ------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# -- Editor / IDE ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo

# -- Jupyter -----------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -- Build / packaging -------------------------------------------------------
dist/
build/
*.egg-info/

# -- Conda / virtual environments --------------------------------------------
env/
venv/
.conda/
